# Bot token do app do Slack (OAuth token do bot instalado no workspace)
# Exemplo de prefixo: xoxb-
# Nunca commite token real no Git.
SLACK_BOT_TOKEN=

# App token para Socket Mode
# Exemplo de prefixo: xapp-
SLACK_APP_TOKEN=

# Canal padrão opcional.
# Preferencialmente use o ID do canal, não o nome visual.
SLACK_CHANNEL=

# Nome do agente/sessão alvo no OpenClaw.
# Use `default` se não houver necessidade de customização.
AGENT_NAME=default
