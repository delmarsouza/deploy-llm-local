# Token do bot criado no @BotFather via /newbot
# Nunca commite um token real no Git.
TELEGRAM_BOT_TOKEN=

# IDs autorizados a falar com o bot.
# Pode usar uma lista separada por vírgula.
# Exemplo: 7680747272,123456789
TELEGRAM_ALLOW_FROM=

# Nome do agente/sessão alvo no OpenClaw.
# Use `default` se não houver necessidade de customização.
AGENT_NAME=default
